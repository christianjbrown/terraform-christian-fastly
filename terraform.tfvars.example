# The only input is the Fastly token, and it is best supplied via the environment
# (never a committed file):
#   export FASTLY_API_KEY="..."
#
# The X-Request-Auth secret is NOT set here — Terraform reads it from GCP Secret
# Manager. You just need GCP credentials for the google provider + GCS backend:
#   export GOOGLE_OAUTH_ACCESS_TOKEN="$(gcloud auth print-access-token)"
#   # or Application Default Credentials, or (in CI) Workload Identity Federation.
#
# If you ever add other variables, a real terraform.tfvars is gitignored — keep it that way.
